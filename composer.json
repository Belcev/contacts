{
  "name": "belcev/contacts",
  "type": "project",
  "description": "sample project for importing contacts",
  "license": "MIT",
  "authors": [
    {
      "name": "Belcev"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "ext-xmlreader": "*",
    "laravel/framework": "^12.0"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2.0",
    "fakerphp/faker": "^1.23",
    "larastan/larastan": "^3.0",
    "laravel/breeze": "^2.3",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.8",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.4",
    "rector/rector": "^2.0",
    "slevomat/coding-standard": "8.22.1",
    "symplify/easy-coding-standard": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cache": [
      "php artisan cache:clear --no-interaction",
      "php artisan config:clear --no-interaction",
      "php artisan event:clear --no-interaction"
    ],
    "setup": [
      "composer install",
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php ./artisan key:generate",
      "@php ./artisan migrate --force",
      "npm install",
      "npm run build"
    ],
    "phpstan": "php -d memory_limit=4G vendor/bin/phpstan analyse --configuration=phpstan.neon",
    "phpstan:baseline": "php -d memory_limit=4G vendor/bin/phpstan analyse --generate-baseline",
    "ecs": "vendor/bin/ecs check --config=ecs.php",
    "ecs:fix": "vendor/bin/ecs check --config=ecs.php --fix",
    "rector": "vendor/bin/rector --dry-run",
    "rector:fix": "vendor/bin/rector",
    "fix": [
        "composer run rector:fix",
        "composer run ecs:fix"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php ../artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
    ],
    "test": [
      "@php ./artisan config:clear --ansi",
      "@php ./artisan test"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php ./artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php ./artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php ./artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php ./artisan migrate --graceful --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
